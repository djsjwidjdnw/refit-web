# ReFit web — copy to .env.local and fill in. NEVER commit .env.local or any secret key.
# The app/build runs fine with the Stripe vars BLANK (billing features just no-op until set).

# ── Supabase (same project as the mobile app) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable anon key>

# Service-role key — SERVER ONLY. Used solely by the Stripe webhook to write
# shop_entitlements (bypasses RLS). Never expose to the browser / never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ── Site ─────────────────────────────────────────────────────────────────────
# Public origin, used to build Stripe success/return URLs. Optional — falls back to the
# request host. Set to your production URL in Vercel.
NEXT_PUBLIC_SITE_URL=https://refit-iq.com

# ── Stripe ───────────────────────────────────────────────────────────────────
# Secret key (SERVER ONLY). sk_test_… in test mode, sk_live_… in production.
STRIPE_SECRET_KEY=<stripe secret key>
# Publishable key. Reserved for future client-side Stripe.js; the hosted-checkout redirect
# used here does not require it, but set it so it's ready.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe publishable key>
# Webhook signing secret (whsec_…) from the webhook endpoint you register in Stripe.
STRIPE_WEBHOOK_SECRET=<stripe webhook signing secret>

# Per-plan price IDs (price_…). Create these products/prices in Stripe (see
# docs/STRIPE_SETUP.md), then paste each price id here. Annual = 2 months free (monthly ×10).
STRIPE_PRICE_LITE_MONTHLY=<price id — Lite $99/mo>
STRIPE_PRICE_LITE_ANNUAL=<price id — Lite $990/yr>
STRIPE_PRICE_PRO_MONTHLY=<price id — Pro $179/mo>
STRIPE_PRICE_PRO_ANNUAL=<price id — Pro $1790/yr>
STRIPE_PRICE_MAX_MONTHLY=<price id — Max $299/mo>
STRIPE_PRICE_MAX_ANNUAL=<price id — Max $2990/yr>
# Optional: add-on seat price ($15/tech/mo). Reserved for future seat-management UI.
STRIPE_PRICE_ADDON_SEAT=<price id — add-on seat $15/mo>
